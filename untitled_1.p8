pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	p_init()
	x=32
	y=64
	x2=32
	y2=80
	r=cocreate(function()
		for i=1,30 do
			x+=1
			yield()
		end
	end)
	g=cocreate(function()
		for i=1,30 do
			x2+=1
			yield()
		end
	end)
end

function _update()
	p_update()
	coresume(r)
	coresume(g)
end

function _draw()
	cls(0)
	rectfill(x,y,x+8,y+8,7)
	rectfill(x2,y2,x2+8,y2+8,9)
	map()
	p_draw()
end
-->8
--player
local s_idle=0
local s_move=1

function p_init()
	p={x=1,y=1,st=s_idle}
	sp={6,7}
	t,f,s=0,1,6 --tick,frame,step
end

function p_update()
		if btn(⬅️) and p.x>1 
			do p.x-=1 end
		if btn(➡️) and p.x<127-8 
			do p.x+=1 end
		if btn(⬇️) and p.y<127-8
			do p.y+=1 end
		if btn(⬆️) and p.y>1
			do p.y-=1 end
	
		t=(t+1)%s
		if (t==0) f=f%#sp+1
end

function p_draw()
	spr(sp[f],p.x,p.y)
end
