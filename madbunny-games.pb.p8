version 43
__lua__
function _init()
	intro_init()
end

function _updates()
end

function _draw()
	cls()
	intro()
	cls()
	--map()
end

function wait(a)
for i = 1,a do flip() end
end
-->8
function place_tiles()
 for x=0,15 do
 	for y=0,15 do
 	--	mset(x,y,2)
 	end
 end
end
-->8
local pdone=false

function intro_init()
	start_done=false
	sfade=0
end

function intro()
	wait(15)
	while start_done == false do
		startup()
		sfade+=1
		cls()
	end
end

function startup()
	sspr(24,0,16,15,64,64)
	draw_text()
	rectfill(64-14,64+19+sfade,64+32,64+32,0)
	ponce()
	wait(3)

	if (sfade>13) do
		cls()
		sspr(40,0,16,15,64,64)
		draw_text()
		wait(2)
		cls()
		sspr(56,0,16,15,64,64)
		draw_text()
		wait(50)
		start_done=true
	end
end

function ponce()
	if pdone == false do
		wait(40)
		pdone=true
	end
end

function draw_text()
	sspr(0,15,47,19,64-14,64+19)
	sspr(47,15,47,19,64-4,64+26)
end
