function star_init()
	starx={}
	stary={}
	
	for i=1,100 do
		add(starx,rnd(128))
		add(stary,rnd(128))
	end
end

function stars()
-- for x=0,15 do
-- 	for y=0,15 do
-- 	end
-- end
	for i=1,100 do
		pset(starx[i],stary[i],7)
	end
end
-->8
local pdone=false

function intro_init()
	start_done=false
	sfade=0
end

function intro()
	if start_done == false do
		cls()
		wait(15)
		while start_done == false do
			startup()
			sfade+=1
			cls()
		end
	end
end

function startup()
	sspr(24,0,16,15,64,64)
	draw_text()
	rectfill(64-14,64+19+sfade,64+32,64+32,0)
	ponce()
	wait(3)

	if (sfade>13) do
		cls()
		sspr(40,0,16,15,64,64)
		draw_text()
		wait(2)
		cls()
		sspr(56,0,16,15,64,64)
		draw_text()
		wait(50)
		start_done=true
	end
end

function ponce()
	if pdone == false do
		wait(40)
		pdone=true
	end
end

function draw_text()
	sspr(0,15,47,19,64-14,64+19)
	sspr(47,15,47,19,64-4,64+26)
end
-->8
--menu
function menu_init()
	fs={fr=5,9,10}
	opts={
		{i=1,txt="normal"},
		{i=2,txt="arcade"}
	}
	cur=1
	i=1
	t=0
end

function menu()
	box(32,15)
	
	choice(48,55,opts[1])
	choice(48,65,opts[2])
end

function choice(x,y,opt)
	if cur==opt.i then
		drw_ar(x-10,y-2)
	end
	print(opt.txt,x,y)
end

function drw_ar(x,y)
	spr(fs[i],x,y)
	if t<fs.fr then
	t+=1
	else
		if (i<2) then
			i+=1
		else
			i=1
		end
		t=0
	end
end

function box(w,h)
	-- center alined
	local cx=64
	local cy=64
	rectfill(cx-w,cy-h,cx+w,cy+h,0)
	rect(cx-w,cy-h,cx+w,cy+h,7)
end
