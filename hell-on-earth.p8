-->8
--player

function p_init()
	p={x=1,y=3}
	sp={6,7}
	t,f,s=0,1,6 --tick,frame,step
end

function p_update()
	rt={
		x=(p.x+1)*8,y=p.y*8,
		x2=((p.x+1)*8)+8,y2=((p.y+1)*8)
	}
	lt={
		x=(p.x-1)*8,y=p.y*8,
		x2=((p.x-1)*8)+8,y2=((p.y+1)*8)
	}
	up={
		x=p.x*8,y=(p.y*8)-8,
		x2=((p.x+1)*8),y2=((p.y+1)*8)-8
	}
	dwn={
		x=p.x*8,y=(p.y*8)+8,
		x2=((p.x+1)*8),y2=((p.y+1)*8)+8
	}
	if btnp(⬅️) and not btn(🅾️) then
		if canmove(⬅️) do p.x-=1 end
	end
	if btnp(➡️) and not btn(🅾️) then
		if canmove(➡️) do p.x+=1 end
	end
	
	if btnp(⬆️) then
		if canmove(⬆️) do p.y-=1 end
	end
	if btnp(⬇️) then
		if canmove(⬇️) do p.y+=1 end
	end
	
	if btn(🅾️) then
		if btnp(➡️) then
			action(➡️)
		end
		if btnp(⬅️) then
			action(⬅️)
		end
	end
	
	t=(t+1)%s
	if (t==0) f=f%#sp+1
end

function p_draw()
--	rect(rt.x,rt.y,rt.x2,rt.y2)
--	rect(lt.x,lt.y,lt.x2,lt.y2)
--	rect(up.x,up.y,up.x2,up.y2,4)
--	rect(dwn.x,dwn.y,dwn.x2,dwn.y2,5)
--	print(f)
	spr(sp[f],p.x*8,p.y*8)

end
-->8
--collisions
function canmove(dir)		
	if isblocked(getmtile(dir)) then
		return false end
	
	if dir == ➡️ then
		local nx = (p.x+1)*8
		if nx>120 then 
			return false end
--		if getmtile(➡️) == 34 then
--			return false end
	end
	
	if dir == ⬅️ then
		nx = (p.x-1)*8
		if nx<0 then
			return false end
	end
	
	if dir == ⬆️ then
		local nx = (p.y-1)*8
		if nx<0 then
			return false end
	end
	
	if dir == ⬇️ then
		local nx = (p.y+1)*8
		if nx>120 then
			return false end
	end
	
	return true
end

function isblocked(tile)
	return fget(tile,0)
end

function getmtile(dir)
	local s
	if dir == ➡️ then
		s = mget((rt.x/8),(rt.y/8))
	end
	if dir == ⬅️ then
		s=mget((lt.x/8),(lt.y/8))
	end
	if dir == ⬇️ then
		s=mget((dwn.x/8),(dwn.y/8))
	end
	if dir == ⬆️ then
		s=mget((up.x/8),(up.y/8))
	end
	return s
end
-->8
function action(dir)
	if dir==➡️ do
		printh("action "..➡️)
		-- check for item
		local i=getmtile(➡️)
		if i==34 do
			sfx(1)
		end
	end
	
	if dir==⬅️ do
		printh("action "..⬅️)
	end
	
	sfx(0)
end
