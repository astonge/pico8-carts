pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	p_init()
	x=32
	y=64
	x2=32
	y2=80
	r=cocreate(function()
		for i=1,30 do
			x+=1
			yield()
		end
	end)
	g=cocreate(function()
		for i=1,30 do
			x2+=1
			yield()
		end
	end)
end

function _update()
	p_update()
	coresume(r)
	coresume(g)
end

function _draw()
	cls(0)
	rectfill(x,y,x+8,y+8,7)
	rectfill(x2,y2,x2+8,y2+8,9)
	map()
	p_draw()
end
-->8
--player
local s_idle=0
local s_move=1

function p_init()
	p={x=1,y=3,st=s_idle}
	sp={6,7}
	t,f,s=0,1,6 --tick,frame,step
end

function p_update()
	rt={
		x=(p.x+1)*8,y=p.y*8,
		x2=((p.x+1)*8)+8,y2=((p.y+1)*8)
	}
	lt={
		x=(p.x-1)*8,y=p.y*8,
		x2=((p.x-1)*8)+8,y2=((p.y+1)*8)
	}
	up={
		x=p.x*8,y=(p.y*8)-8,
		x2=((p.x+1)*8),y2=((p.y+1)*8)-8
	}
	dwn={
		x=p.x*8,y=(p.y*8)+8,
		x2=((p.x+1)*8),y2=((p.y+1)*8)+8
	}
	if btnp(⬅️) then
		if canmove(⬅️) do p.x-=1 end
	end
	if btnp(➡️) then
		if canmove(➡️) do p.x+=1 end
	end
	
	if btnp(⬇️) then
		if canmove(⬇️) do p.y+=1 end
	end
	
	t=(t+1)%s
	if (t==0) f=f%#sp+1
end

function p_draw()
--	rect(rt.x,rt.y,rt.x2,rt.y2)
--	rect(lt.x,lt.y,lt.x2,lt.y2)
--	rect(up.x,up.y,up.x2,up.y2,4)
--	rect(dwn.x,dwn.y,dwn.x2,dwn.y2,5)
	spr(sp[f],p.x*8,p.y*8)

end

function canmove(dir)		
	if dir == ➡️ then
		nx = (p.x+1)*8
		if nx>120 then 
			return false end
		if getspr(➡️) == 34 then
			return false end
	end
	
	if dir == ⬅️ then
		nx = (p.x-1)*8
		if nx<0 then
			return false end
	end
	
	return true
end

function getspr(dir)
	if dir == ➡️ then
		s = mget((rt.x/8),(rt.y/8))
		printh("spr: "..s)	
		return s
	end
end
